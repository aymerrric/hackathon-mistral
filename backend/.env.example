# Copy to .env and fill in. Loaded by app/config.py (pydantic-settings).

DATABASE_URL=postgresql+psycopg://calltree:calltree@localhost:5432/calltree

# Mistral API key — used for tree generation, call analysis (chat models)
# and speech-to-text (Voxtral).
MISTRAL_API_KEY=your-key-here

# Chat model for tree generation and call judging.
MISTRAL_CHAT_MODEL=mistral-large-latest
# Transcription model.
MISTRAL_AUDIO_MODEL=voxtral-mini-latest

# Where uploaded audio files are stored on disk.
MEDIA_DIR=./media

# Comma-separated origins allowed by CORS (the Next.js dev server).
CORS_ORIGINS=http://localhost:3000
